# ─── Sanity CMS ──────────────────────────────────────────────────────────────
# Get these from https://sanity.io/manage → your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token (for server-side mutations — optional for read-only)
# Create at: sanity.io/manage → API → Tokens → Add API token (Editor)
SANITY_API_TOKEN=your_token_here

# ─── Contact Form ─────────────────────────────────────────────────────────────
# Web3Forms — free, no backend needed: https://web3forms.com
NEXT_PUBLIC_WEB3FORMS_KEY=your_web3forms_key_here

# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
